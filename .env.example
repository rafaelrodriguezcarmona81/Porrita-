# Archivo de ejemplo: copia a .env y rellena con tus valores
# NO subas .env a Git (está en .gitignore)

# Clave para desbloquear el panel Admin en local
ADMIN_TRIGGER_SECRET=tu_clave_segura_aqui

# Token de GitHub para disparar la Action (opcional)
# Genera uno en: https://github.com/settings/tokens (scope: repo)
# Cada desarrollador debe tener su propio token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
